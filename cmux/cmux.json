[
  {
    "name": "AI Coding (Claude + Codex)",
    "description": "Full agent workspace: Claude Code with agent teams + Codex + shell",
    "keywords": ["ai", "coding", "agents", "claude", "codex"],
    "restart": "confirm",
    "workspace": {
      "name": "AI Coding",
      "color": "Purple",
      "layout": {
        "direction": "horizontal",
        "split": 0.5,
        "children": [
          {
            "pane": {
              "surfaces": [
                {
                  "type": "terminal",
                  "name": "Claude",
                  "command": "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 claude --dangerously-skip-permissions",
                  "focus": true
                }
              ]
            }
          },
          {
            "layout": {
              "direction": "vertical",
              "split": 0.5,
              "children": [
                {
                  "pane": {
                    "surfaces": [
                      {
                        "type": "terminal",
                        "name": "Codex",
                        "command": "codex --yolo"
                      }
                    ]
                  }
                },
                {
                  "pane": {
                    "surfaces": [
                      {
                        "type": "terminal",
                        "name": "Shell"
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    }
  },
  {
    "name": "AI Coding (Claude Only)",
