                }
              ]
            }
          }
        ]
      }
    }
  },
  {
    "name": "Claude Teams",
    "description": "Launch Claude Code with native cmux teammate splits",
    "keywords": ["teams", "swarm", "multi-agent"],
    "command": "cmux claude-teams"
  },
